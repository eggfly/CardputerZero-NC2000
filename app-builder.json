{
  "package_name": "nc2000",
  "version": "1.0.3",
  "app_name": "NC2000",
  "bin_name": "nc2000",
  "description": "Wenquxing NC2000 emulator — LVGL port loaded via cz_app.h",
  "runtime": "lvgl-dlopen",
  "lvgl_version": "9.5",
  "caps": ["keyboard", "audio"],
  "cmake_args": [
    "-DENABLE_PORT_LVGL=ON",
    "-DCZ_SDK_DIR=${CZ_SDK_DIR}",
    "-DCZ_LVGL_DIR=${CZ_LVGL_DIR}"
  ],
  "cmake_target": "nc2000_lvgl",
  "env": {
    "NC2000_ROM_DIR": "${APP_DIR}"
  },
  "store": {
    "summary": "WenQuXing NC2000/NC1020 emulator for CardputerZero 320x170 display",
    "locales": {
      "zh-CN": {
        "title": "NC2000 文曲星模拟器",
        "summary": "适配 CardputerZero 320x170 屏幕的文曲星 NC2000/NC1020 模拟器"
      },
      "zh-TW": {
        "title": "NC2000 文曲星模擬器",
        "summary": "適配 CardputerZero 320x170 螢幕的文曲星 NC2000/NC1020 模擬器"
      }
    },
    "categories": ["Emulators", "Games"],
    "license": "MIT",
    "source_repo": "https://github.com/eggfly/CardputerZero-NC2000",
    "icon": "icon.png",
    "screenshots": ["screenshots/main.png"],
    "permissions": {
      "audio_output": true,
      "keyboard_input": true,
      "network": false
    }
  }
}
